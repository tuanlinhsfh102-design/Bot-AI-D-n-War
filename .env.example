# =====================================================
# Zalo Sleiz Bot — Environment Variables
# Copy file này thành .env và điền giá trị
#   Windows CMD:  copy .env.example .env
#   Linux/Mac:    cp .env.example .env
# =====================================================
#
# 🔑 HỆ THỐNG API KEY THÔNG MINH
# -------------------------------
# Có 3 cách cung cấp key — chọn 1 hoặc kết hợp:
#
#   Cách 1 — File .env (đơn giản nhất):
#     GOOGLE_GENERATIVE_AI_API_KEY=AIza...key1
#
#   Cách 2 — Nhiều key qua env var (rotation tự động):
#     GOOGLE_GENERATIVE_AI_API_KEYS=AIza...key1,AIza...key2,AIza...key3
#     # Dấu phân cách: , ; | hoặc xuống dòng
#
#   Cách 3 — HOT-RELOAD từ folder data/api_keys/ (KHUYẾN NGHỊ!):
#     Drop file vào data/api_keys/, bot TỰ nhặt không cần restart:
#
#     data/api_keys/gemini.txt          ← nhiều key, mỗi dòng 1 key
#     data/api_keys/brave.txt           ← key Brave Search
#     data/api_keys/gemini_mywork.txt   ← 1 key, auto-label "mywork"
#     data/api_keys/gemini_backup.txt   ← 1 key, auto-label "backup"
#
#   File có thể là:
#     - 1 dòng đơn: AIza...key1
#     - Nhiều dòng: AIza...key1\nAIza...key2\nAIza...key3
#     - Label + keys (file nhiều dòng): label_mywork\nAIza...key1\nAIza...key2
#
# Tính năng smart (xem src/module/apikey.ts):
#   - Health-weighted rotation: ưu tiên key khoẻ nhất
#   - Auto-cooldown: 429/quota → 10 phút, 401/403 → 30 phút
#   - Auto-blacklist: 3 lần 401/403 → DEAD vĩnh viễn
#   - Quota tracking: tự cooldown nếu spam > 30 calls/phút/key
#   - Persistent state: data/api_key_state.json → restart vẫn nhớ
#   - Revive check: thử lại key DEAD mỗi 1 giờ
#   - Admin tools: gọi ListApiKeys / AddApiKey / RemoveApiKey / ReviveApiKey
#                   qua chat với bot (xem AiTool.ts)
#
# =====================================================

# ─────────────────────────────────────────────────────
# Google Gemini API Key (BẮT BUỘC)
# ─────────────────────────────────────────────────────
# Bot dùng Gemini cho: chat AI, summarize history,
# image/video to text, TTS voice, RoastPerson tool.
# Không có key bot sẽ KHÔNG chạy.
#
# Cách lấy:
#   1. Truy cập: https://aistudio.google.com/apikey
#   2. Đăng nhập Google account
#   3. Click "Create API Key"
#   4. Copy key (bắt đầu bằng "AIza...")
#
# SINGLE key (Cách 1):
GOOGLE_GENERATIVE_AI_API_KEY=
# MULTI key (Cách 2 — phân cách bằng , hoặc ; hoặc | hoặc xuống dòng):
GOOGLE_GENERATIVE_AI_API_KEYS=
# Alias tương đương: GEMINI_API_KEY / GOOGLE_API_KEY / GOOGLE_AI_API_KEY
# (cả single và multi đều có alias tương ứng: GEMINI_API_KEYS, GOOGLE_API_KEYS, ...)
#
# 💡 Cách 3 (data/api_keys/) không cần env var này — drop file là xong.

# ─────────────────────────────────────────────────────
# Brave Search API Key (TUỲ CHỌN)
# ─────────────────────────────────────────────────────
# Chỉ cần nếu muốn dùng tool WebSearchBrave (để verify khi user nổ).
# Bot vẫn chạy bình thường nếu không có.
#
# Lấy tại: https://brave.com/search/api/ (free tier: 2000 queries/tháng)
BRAVE_API_KEY=
# MULTI key:
BRAVE_API_KEYS=
# Alias tương đương:
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_API_KEYS=

# ─────────────────────────────────────────────────────
# MongoDB (TUỲ CHỌN)
# ─────────────────────────────────────────────────────
# Nếu cấu hình, bot sẽ sync dữ liệu chính lên MongoDB ngoài local files/SQLite.
MONGODB_URI=
MONGODB_DB_NAME=zalo_sleiz_bot

# ─────────────────────────────────────────────────────
# Zalo User Agent (TUỲ CHỌN)
# ─────────────────────────────────────────────────────
# KHÔNG cần điền tay — bot tự quản lý qua file credentials.json
#
# Flow:
#   1. Bot thử đọc credentials.json (cookie+imei+userAgent+uid)
#   2. Nếu hợp lệ → login bằng cookie (KHÔNG cần quét QR)
#   3. Nếu cookie hết hạn hoặc không có → tự sinh ./qr.png để quét
#   4. Sau khi QR thành công → tự LƯU credentials.json để dùng lần sau
#
# Để "reset" → xoá file credentials.json → bot sẽ bắt buộc quét QR lại
#
# ZALO_USER_AGENT chỉ dùng khi quét QR lần đầu (mặc định Firefox 133)
ZALO_USER_AGENT=

# ─────────────────────────────────────────────────────
# Keystore Web UI (BẮT BUỘC BẬT để quản lý key qua web)
# ─────────────────────────────────────────────────────
# Web UI nhỏ để paste/quản lý API key, embed vào main bot.
# Sau khi bot start, mở http://localhost:8787 để quản lý key.
#
# Tính năng: paste key, xem status, xoá key, revive key DEAD.
# Đổi key qua web → bot tự reload không cần restart.
#
# BẬT/TẮT: true (mặc định) | false
KEYSTORE_ENABLED=true
# PORT (mặc định: 8787)
KEYSTORE_PORT=8787
# HOST (mặc định: 127.0.0.1 — chỉ localhost, KHÔNG expose ra ngoài)
# Đổi thành 0.0.0.0 NẾU muốn truy cập từ máy khác (cần đặt sau reverse proxy có auth)
KEYSTORE_HOST=127.0.0.1

# =====================================================
# Các tool MIỄN PHÍ (không cần API key):
# ────────────────────────────────────────────────────
# - GetWeather: Open-Meteo (https://open-meteo.com)
# - RecommendMusic: iTunes Search API
# - SetReminder: lưu SQLite nội bộ
# - GenerateRealisticPhoto: Pollinations (https://pollinations.ai)
# - GetProvokerLine / PickProvokerByLevel / PickProvokerByCategory: load từ data/provoker_lines.txt
# - MatchProvokerLine / PickMultipleProvokers: lọc từ kho
# - GetGroupMembers: dùng zca-js API
# - RoastPerson: dùng Gemini LLM (cần GOOGLE_GENERATIVE_AI_API_KEY)
# =====================================================